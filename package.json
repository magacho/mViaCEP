{
  "name": "mviacep",
  "version": "0.0.2-M2",
  "description": "Browser-side library wrapping the free ViaCEP API for address autofill and validation, framework-agnostic with React, Vue, Angular and vanilla adapters.",
  "license": "MIT",
  "author": "magacho",
  "type": "module",
  "sideEffects": false,
  "keywords": ["cep", "viacep", "endereco", "address", "autofill", "validation", "brasil"],
  "files": ["dist"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/cdn/mviacep.global.js",
  "jsdelivr": "./dist/cdn/mviacep.global.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/adapters/react/index.d.ts",
      "import": "./dist/adapters/react/index.js",
      "require": "./dist/adapters/react/index.cjs"
    },
    "./vue": {
      "types": "./dist/adapters/vue/index.d.ts",
      "import": "./dist/adapters/vue/index.js",
      "require": "./dist/adapters/vue/index.cjs"
    },
    "./angular": {
      "types": "./dist/adapters/angular/index.d.ts",
      "import": "./dist/adapters/angular/index.js",
      "require": "./dist/adapters/angular/index.cjs"
    },
    "./vanilla": {
      "types": "./dist/adapters/vanilla/index.d.ts",
      "import": "./dist/adapters/vanilla/index.js",
      "require": "./dist/adapters/vanilla/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "peerDependencies": {
    "@angular/core": ">=15",
    "react": ">=17",
    "react-dom": ">=17",
    "rxjs": ">=7",
    "vue": ">=3"
  },
  "peerDependenciesMeta": {
    "@angular/core": { "optional": true },
    "react": { "optional": true },
    "react-dom": { "optional": true },
    "rxjs": { "optional": true },
    "vue": { "optional": true }
  },
  "devDependencies": {
    "@angular/core": "^17.3.0",
    "@testing-library/dom": "^9.3.4",
    "@testing-library/react": "^14.3.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^8.57.0",
    "jsdom": "^24.0.0",
    "prettier": "^3.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitepress": "^1.6.4",
    "vitest": "^1.4.0",
    "vue": "^3.4.38",
    "zone.js": "^0.14.10"
  }
}
